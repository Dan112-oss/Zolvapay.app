## ZolvaPay — environment reference.
## Copy the values you need into Railway's "Variables" tab for each service.
## This file is safe to commit (no real secrets) — .env itself is gitignored.

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
APP_NAME=ZolvaPay
APP_ENV=production
# Generate with: php artisan key:generate --show — paste the output here.
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
# Your actual Railway public domain, e.g. https://zolvapay-production.up.railway.app
APP_URL=

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Database (MySQL 8+ required — see config/database.php's own note on why
# sqlite is dev/test-only: WalletService's row locking depends on InnoDB)
# ---------------------------------------------------------------------------
DB_CONNECTION=mysql
# If you're using Railway's MySQL plugin, copy these from its "Connect" tab
# (Railway also provides a single DB_URL / MYSQL_URL — either approach works,
# DB_URL takes precedence over the individual fields below if both are set)
DB_HOST=
DB_PORT=3306
DB_DATABASE=railway
DB_USERNAME=root
DB_PASSWORD=

# ---------------------------------------------------------------------------
# Cache / Session
# ---------------------------------------------------------------------------
CACHE_STORE=database
SESSION_DRIVER=database
SESSION_LIFETIME=120
# true once APP_URL is https (it will be, on Railway)
SESSION_SECURE_COOKIE=true

# ---------------------------------------------------------------------------
# Queue — defaults to 'database' (config/queue.php), so no Redis is required
# to get jobs working. Only change this if you've actually provisioned a
# Redis service and want the extra throughput.
# ---------------------------------------------------------------------------
QUEUE_CONNECTION=database

# ---------------------------------------------------------------------------
# CORS / Sanctum
# ---------------------------------------------------------------------------
# Leave blank: the frontend is served same-origin from public/*.html via this
# same app (routes/web.php), so no cross-origin allowance is needed. Only
# fill this in if you deploy a separate frontend later.
CORS_ALLOWED_ORIGINS=
SANCTUM_STATEFUL_DOMAINS=

# ---------------------------------------------------------------------------
# Mail — used for transfer notifications (SendTransferNotification job).
# 'log' writes emails to the Laravel log instead of sending, so the app
# works with zero mail setup until you're ready to wire a real provider.
# ---------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=no-reply@zolvapay.example
MAIL_FROM_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# KYC document storage
# ---------------------------------------------------------------------------
# 'local' writes to storage/app/private — MUST sit on a Railway persistent
# Volume mounted at that path, or every uploaded KYC document is deleted on
# the next deploy. See DEPLOYMENT.md, "Persistent Volume for KYC documents".
FILESYSTEM_DISK=local

# ---------------------------------------------------------------------------
# FX rates — 'mock' returns fixed fake rates, no key needed. Get a real key
# at https://openexchangerates.org once ready for real rates.
# ---------------------------------------------------------------------------
FX_PROVIDER=mock
FX_API_KEY=
FX_CACHE_MINUTES=30
FX_DEFAULT_MARGIN_BPS=150

# ---------------------------------------------------------------------------
# KYC verification — 'mock' auto-stores submissions for manual admin review,
# no vendor call. Switch to a real provider slug once one is integrated in
# app/Services/Kyc (KycProviderFactory) and its keys are set here.
# ---------------------------------------------------------------------------
KYC_PROVIDER=mock

# ---------------------------------------------------------------------------
# Payment rails (wallet funding/withdrawal) — 'mock' resolves instantly, no
# credentials needed. Flutterwave keys below cover both this AND billers.
# ---------------------------------------------------------------------------
PAYMENT_RAIL_PROVIDER=mock
PAYMENT_RAIL_SECRET_KEY=
PAYMENT_RAIL_PUBLIC_KEY=
PAYMENT_RAIL_WEBHOOK_SECRET=
PAYMENT_RAIL_REDIRECT_URL=
FLUTTERWAVE_BASE_URL=https://api.flutterwave.com/v3

# ---------------------------------------------------------------------------
# Bill payments — 'mock' settles instantly, no credentials needed.
# ---------------------------------------------------------------------------
BILLER_PROVIDER=mock

# ---------------------------------------------------------------------------
# Virtual cards — 'mock' issues fake cards instantly, no credentials needed.
# ---------------------------------------------------------------------------
CARD_PROCESSOR=mock
CARD_PROCESSOR_API_KEY=
CARD_PROCESSOR_API_SECRET=
MARQETA_CARD_PRODUCT_TOKEN=
MARQETA_BASE_URL=https://sandbox-api.marqeta.com/v3
